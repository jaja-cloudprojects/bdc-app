NODE_ENV=production
PORT=4000

# PostgreSQL — utilise un mot de passe fort (16+ caractères, majuscules, chiffres, symboles)
DATABASE_URL="postgresql://bdc_user:CHANGE_MOI_MOT_DE_PASSE_FORT@host:5432/bdc_db?schema=public"

# JWT — génère avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_MOI_SECRET_64_CHARS_MIN
JWT_REFRESH_SECRET=CHANGE_MOI_REFRESH_SECRET_64_CHARS_MIN
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# CORS — liste des origines autorisées (pas de wildcard en prod)
CORS_ORIGIN=https://ton-domaine.com,https://admin.ton-domaine.com

# Admin — mot de passe fort, ne jamais utiliser la valeur par défaut
ADMIN_EMAIL=admin@beauteducil.com
ADMIN_PASSWORD=CHANGE_MOI_MOT_DE_PASSE_FORT

# Supabase
SUPABASE_URL=https://ton-projet.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # Récupérer depuis Supabase Dashboard > Settings > API
SUPABASE_AVATAR_BUCKET=avatars
SUPABASE_DOCUMENTS_BUCKET=documents

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
PUBLIC_BASE_URL=https://api.ton-domaine.com

# Expo Push Notifications
EXPO_ACCESS_TOKEN=ton_token_expo
