# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://bdc_user:bdc_password@localhost:5432/bdc_db?schema=public"

# JWT
JWT_SECRET="change-me-to-a-long-random-string"
JWT_REFRESH_SECRET="change-me-too-different-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# CORS
CORS_ORIGIN="http://localhost:19006,https://beauteducil.com"

# Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760
PUBLIC_BASE_URL="http://localhost:4000"

# Expo Push (optional, mostly used for enhanced error tracking)
EXPO_ACCESS_TOKEN=""

# Admin defaults (for seed)
ADMIN_EMAIL="admin@beauteducil.com"
ADMIN_PASSWORD="ChangeMeNow!"

# Supabase Storage (avatars)
SUPABASE_URL="https://VOTRE_PROJECT_ID.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="votre_service_role_key"
SUPABASE_AVATAR_BUCKET="avatars"
